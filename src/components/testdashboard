import { useCallback, useEffect, useMemo, useState } from "react";
import Card from "../components/Card";
import DataTable from "../components/DataTable";
import FiltersBar from "../components/FiltersBar";
import { fetchDashboard, type DashboardFilters } from "../api/client";
import { quoteReqByPairChannel, TEAM_PRESET_GROUPS } from "../mock/data";
import { useAutoRefresh } from "../hooks/useAutoRefresh";
import { quoteRequestErrors } from "../mock/data";



export default function Dashboard() {
    const [filters, setFilters] = useState<DashboardFilters>({
        teamcodes: [],
        timeframe: "last_60_min",
        cif: "",
        account: "",
        currenctPairs: [],
        errorCodes: []
    });

    const applyFilters = (rows: any[]) => {
        return rows.filter((row) => {

            const matchesCif =
            !filters.cif ||
            row.cif?.toString().toLowerCase().includes(
                filters.cif.toLowerCase()
            );

            const matchesTeam =
            filters.teamcodes.length === 0 ||
            filters.teamcodes.includes(row.teamCode);

            return matchesCif && matchesTeam;
        })
    }

    const [loading, setLoading] = useState(false);
    const [asOf, setAsOf] = useState<string>("");
    const [data, setData] = useState<any>(null);

    const pageSize = 10;
    const [quotePage, setQuotePage] = useState(1);
    const quoteData = quoteRequestErrors ?? [];

    const totalQuotePages = Math.max(
        1,
        Math.ceil(quoteData.length / pageSize)
    );

    const paginatedQuoteErrors = quoteData.slice(
        (quotePage - 1) * pageSize,
        quotePage * pageSize
    );
    

    const load = useCallback(async () => {
        setLoading(true);
        try {
            const res = await fetchDashboard(filters);
            setData(res);
            setAsOf(res.asOf);
        } finally {
            setLoading(false);
        }
    }, [filters]);

    const { enabled, setEnabled, nextInSec } = useAutoRefresh(load, 30 * 60 * 10000);

    useEffect(() => {
        load();
    }, []);

    const applyPresetGroup = (groupName: string) => {
        const codes = TEAM_PRESET_GROUPS[groupName] ?? [];
        setFilters({...filters,teamcodes:codes});
    };

    const asOfLabel = useMemo(() => {
        if (!asOf) return "-";
        try {
            return new Date(asOf).toLocaleString();
        } catch {
            return asOf;
        }
    }, [asOf]);

    const kpis = useMemo(() => {
        const quoteErr = (data?.quoteRequestErrors ?? []).reduce((a: number, r: any) => a + (r.count ?? 0), 0);
        const bookErr = (data?.bookingRequestErrors ?? []).reduce((a: number, r: any) => a + (r.count ?? 0), 0);
        const booked = (data?.bookedTrades ?? []).length ?? 0;
        const revenue = (data?.revenueByChannel ?? []).reduce((a: number, r: any) => a + (r.count ?? 0), 0);
        console.log("Computed KPIS: ", {
            quoteErr,
            bookErr,
            booked,
            revenue
        });
        return [
            { label: "Quote Errors", value: quoteErr.toLocaleString() },
            { label: "Booking Errors", value: bookErr.toLocaleString() },
            { label: "Booked Trades", value: booked.toLocaleString() },
            { label: "Total Revenue", value: "$" + revenue.toLocaleString() }

        ];
    }, [data]);

    return (
        <div className="page">
            <div className="topbar">
                <div className="brand">
                    <h1>FX Channel Monitoring Dashboard</h1>
                                    </div>

                <div className="actions">
                    <span className="pill">{loading ? "Refreshing.." : `As of: ${asOfLabel}`} </span>
                    <button className="btn secondary" onClick={() => setEnabled(!enabled)} type="button">
                        Auto Refresh: {enabled ? "ON" : "OFF"} {enabled ? `(${nextInSec}s)` : ""}
                    </button>
                    <button className="btn" onClick={load} type="button">
                        Manual Refresh
                    </button>
                </div>
            </div>

            <div className="grid">
                <Card title="KPIs" right="High-level health (mock)">
                    <div className="kpiRow">
                        {kpis.map((k) => (
                            <div
                            key={k.label}
                            style={{
                                border: "1px solid var(--border)",
                                borderRadius: 14,
                                padding: 14,
                                background: "rgba(255, 255, 255, 0.94)"
                            }}
                            >
                            <div style={{ color: "black", fontSize: 12 }}>{k.label}</div>
                            <div style={{ fontSize: 22, fontWeight: 800, marginTop: 6 }}>{k.value}
                                </div>
                                </div>
                        ))}
                    </div>
                </Card>

                <FiltersBar filters={filters} setFilters={setFilters} onApplyPresetGroup={applyPresetGroup} />

                <Card title="Quote Request By Currency Pair and Channel" right="Success /Failure Counts & % by requesting cjannel">
                <p className= "card-description">
                    Quote Request by Currency Pair and Channel refers to the process where a trader asks for specific, executable exchange rates for a chosen pair (e.g., EUR/USD) 
                    through a particular medium (e.g., FIX API, chat, or voice). This mechanism allows institutional traders to secure tailored, 
                    competitive pricing for large transactions directly from liquidity providers before executing a trade
                </p>
                <DataTable
                dense
                columns={[
                    { key: "currencyPair", header: "Currency Pair" },
                    { key: "channel", header: "Channel" },
                    { key: "success", header: "Success" },
                    { key: "successPct", header: "Success %" },
                    { key: "failure", header: "Failure" },
                    { key: "failurePct", header: "Failure %" },
                     { key: "total", header: "Total" }

                ]}
                rows={data?.quoteReqByPairChannel ?? []}
                />               
                </Card>

                <Card title="Quote Request Errors By Error Code and Channel" right="Quote related errors by requesting channel">
                    <p className= "card-description">
                    Quote Request Errors BY Error Code and Channel refers to the systematic categorization of failures that occur during the Request for Quotation (RFQ) process, 
                    organized by specific error codes and the sales channel (e.g., API, web portal, mobile app) where they occurred. It highlights the technical or business-rule violations 
                    (e.g., invalid input, authentication failure) mapped to where the user or system initiated the request to troubleshoot and resolve issues
                </p>
                <DataTable
                dense
                columns={[
                    { key: "errorCode", header: "Error Code" },
                    { key: "errorDescription", header: "Error description" },
                    { key: "sourceService", header: "Source Service" },
                    { key: "channel", header: "Channel" },
                    { key: "count", header: "Count" }

                ]}
                rows={paginatedQuoteErrors}
                />    
                <div className="pagination">
                    <button
                    disabled={quotePage === 1}
                    onClick={() => setQuotePage(p => p -1)}
                    >
                        « Prev
                    </button>

                    {Array.from({ length: totalQuotePages }, (_, i) => (
                        <button
                        key={i}
                        className={quotePage === i+1 ? "active" : ""}
                        onClick={() => setQuotePage(i+1)}
                        >
                            {i+1}
                        </button>
                    ))}

                    <button
                    disabled={quotePage === totalQuotePages}
                    onClick={() => setQuotePage(p => p+1)}
                    >
                        Next »
                    </button>
                </div>
                </Card>

                <Card title="Booking Request Errors By Error Code and Channel" right="Booking related errors by requesting channel">
                    <p className= "card-description">
                    Booking Request Errors by Error Code and Channel refers to the systematic classification of reservation failures (e.g., 400 Bad Request, 403 Forbidden) 
                    based on the specific sales channel (e.g., Booking.com, Expedia) where the error originated. This approach allows developers and hoteliers to pinpoint whether booking failures are due to invalid data, API connectivity issues, 
                    or mapping discrepancies, enabling targeted troubleshooting.
                </p>
                <DataTable
                dense
                columns={[
                    { key: "errorCode", header: "Error Code" },
                    { key: "errorDescription", header: "Error description" },
                    { key: "sourceService", header: "Source Service" },
                    { key: "channel", header: "Channel" },
                    { key: "count", header: "Count" }

                ]}
                rows={data?.bookingRequestErrors ?? []}
                />               
                </Card>

                 <Card title="Quote Request" right="Indicative $ Executable quote requests (mock)">
                    <p className= "card-description">
                    Quote Request is a formal document used to ask vendors for pricing, availability, and delivery details for specific goods or services. It allows businesses to 
                    compare competing offers to ensure they receive the best value and quality before making a purchasing decision..
                </p>
                <DataTable
                dense
                columns={[
                    { key: "teamCode", header: "Team Code" },
                    { key: "client", header: "Client" },
                    { key: "user", header: "User" },
                    { key: "phone", header: "Phone" },
                    { key: "email", header: "Email" },
                    { key: "cif", header: "CIF" },
                    { key: "account", header: "Account" },
                    { key: "timestamp", header: "TimeStamp" },
                    { key: "channelCode", header: "Channel Code" },
                    { key: "indicative", header: "Indicative (yes/No)" },
                    { key: "executable", header: "Executable (Yes/No" },
                    { key: "buyCcy", header: "Buy Currency" },
                    { key: "buyAmt", header: "Buy Amount" },
                    { key: "sellCcy", header: "Sell Currency" },
                    { key: "sellAmt", header: "Sell Amount" }

                ]}
                rows={applyFilters(data?.quoteRequests ?? [])}
                />               
                </Card>

                 <Card title="Booked Trades" right="Trade Successfully booked in WSS (mock)">
                     <p className= "card-description">
                    Booked trades refer to the final recording and validation of a executed financial transaction into a firm’s official system for record-keeping, 
                    risk management, and regulatory reporting. This post-trade process ensures all details—such as price, quantity, and counterparty—are accurately 
                    stored to calculate profit and loss and enable settlement
                </p>
                <DataTable
                dense
                columns={[
                    { key: "teamCode", header: "Team Code" },
                    { key: "client", header: "Client" },
                    { key: "user", header: "User" },
                    { key: "phone", header: "Phone" },
                    { key: "email", header: "Email" },
                    { key: "cif", header: "CIF" },
                    { key: "account", header: "Account" },
                    { key: "timestamp", header: "TimeStamp" },
                    { key: "channelCode", header: "Channel Code" },
                    { key: "wssDealNumber", header: "WSS Deal Number" }                    
                ]}
                rows={applyFilters(data?.bookTrades ?? [])}
                />               
                </Card>

                 <Card title="SVB Go File Upload" right="Executable file import payments booked in WSS (mock)">
                     <p className= "card-description">
                    SVB Go File Upload is a feature, often used in corporate banking (like GBTI Go Banking), that allows users to securely submit a structured file containing multiple 
                    transactions—such as payroll, vendor payments, or bulk transfers—in a single action. It streamlines high-volume processing by allowing users to upload CSV, XLS, or TXT files, which the system then validates,
                     processes, and archives, rather than requiring manual, single-screen entries
                </p>
                <DataTable
                dense
                columns={[
                    { key: "teamCode", header: "Team Code" },
                    { key: "client", header: "Client" },
                    { key: "user", header: "User" },
                    { key: "phone", header: "Phone" },
                    { key: "email", header: "Email" },
                    { key: "cif", header: "CIF" },
                    { key: "account", header: "Account" },
                    { key: "timestamp", header: "TimeStamp" },
                    { key: "sourceCode", header: "Source Code" },
                    { key: "wssDealNumber", header: "WSS Deal Number" },
                    { key: "tradeDate", header: "Trade Date" },
                    { key: "buyCcy", header: "Buy Currency" },
                    { key: "buyAmt", header: "Buy Amount" },
                    { key: "rate", header: "Rate Amount" },
                    { key: "sellCcy", header: "Sell Currency" },
                    { key: "sellAmt", header: "Sell Amount" },
                    { key: "valueDate", header: "Value Date" }

                ]}
                rows={applyFilters(data?.fileUploads ?? [])}
                />               
                </Card>

                <Card title="Error Code Trade Details" right="Full Trade details for all errors (mock)">
                    <p className= "card-description">
                    Error Code Trade Details refers to a specific identifier and accompanying data generated when a financial transaction fails to execute or settle properly, such as rejected orders, incorrect quantities, or price mismatches. It provides technical information (like a code and message) that helps traders
                     and compliance teams identify, diagnose, and rectify the specific cause of the trade error.
                </p>
                <DataTable
                dense
                columns={[
                    { key: "errorCode", header: "Error Code" },
                    { key: "errorDescription", header: "Error Description" },
                    { key: "sourceService", header: "Source Service" },
                    { key: "channelCode", header: "Channel Code" },
                    { key: "teamCode", header: "Team Code" },
                    { key: "client", header: "Client" },
                    { key: "user", header: "User" },
                    { key: "phone", header: "Phone" },
                    { key: "email", header: "Email" },
                    { key: "cif", header: "CIF" },
                    { key: "account", header: "Account" },
                    { key: "timestamp", header: "TimeStamp" },
                    { key: "tradeDate", header: "Trade Date" },
                    { key: "ccyPair", header: "Currency Pair" },
                    { key: "buyCcy", header: "Buy Currency" },
                    { key: "buyAmt", header: "Buy Amount" },
                    { key: "sellCcy", header: "Sell Currency" },
                    { key: "sellAmt", header: "Sell Amount" },
                    { key: "valueDate", header: "Value Date" }

                    ]}
                rows={applyFilters(data?.errorCodeTradeDetails ?? [])}
                />               
                </Card>

                 <Card title="Revenue By Channel" right="Revenue generated by each channel">
                     <p className= "card-description">
                    Revenue by Channel tracks the total income generated from each distinct sales platform—such as your website, retail locations, or third-party marketplaces.
                     It provides crucial insights into which channels are most profitable, 
                    helping businesses optimize marketing efforts and allocate resources to the highest-performing areas.
                </p>
                <DataTable
                dense
                columns={[
                    { key: "channel", header: "Channel" },
                    { key: "revenue", header: "Revenue" }

                ]}
                rows={data?.revenueByChannel ?? []}
                /> 
                <div style={{ margin: 10, color: "black", fontSize: 12}} >
                    Manual refresh +auto refresh every 30 minutes (toggle above).
                    </div>

                </Card>
            </div>
            </div>

    )
}
